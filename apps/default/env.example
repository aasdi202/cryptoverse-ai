# =============================================================================
# CryptoVerse AI — Environment Variables Reference (env.example)
# =============================================================================
#
# Copy this file to .env.local and fill in values when integrating real APIs.
# All variables must be prefixed with VITE_ to be exposed to the browser bundle.
#
# Current app status: FULLY FUNCTIONAL without any of these keys.
# The simulation engines in src/lib/*Simulator.ts provide all data.
#
# Future integration path:
#   1. Fill in a key below in your .env.local
#   2. The corresponding store will detect it via src/lib/env.ts
#   3. Real API calls replace the simulated fallback automatically
#
# SECURITY NOTES:
#   - Exchange API secrets should NEVER be in a browser-side .env file.
#     Use a server-side proxy (Supabase Edge Function / Cloudflare Worker).
#   - Twitter Bearer Token and News API key are read-only — browser exposure
#     is lower risk but still not recommended for production.
# =============================================================================


# ── On-Chain Analysis ──────────────────────────────────────────────────────────
# Provider docs:
#   Etherscan  → https://docs.etherscan.io/getting-started/viewing-api-usage-statistics
#   BscScan    → https://docs.bscscan.com
#   Solana RPC → https://solana.com/docs/rpc

VITE_ETHERSCAN_API_KEY=
VITE_BSCSCAN_API_KEY=
VITE_SOLANA_RPC_URL=


# ── Sentiment Analysis ─────────────────────────────────────────────────────────
# Provider docs:
#   Twitter/X  → https://developer.twitter.com/en/docs/twitter-api
#   Reddit     → https://www.reddit.com/dev/api  (OAuth2 app credentials)
#   NewsAPI    → https://newsapi.org/docs

VITE_TWITTER_BEARER_TOKEN=
VITE_REDDIT_CLIENT_ID=
VITE_REDDIT_CLIENT_SECRET=
VITE_NEWS_API_KEY=


# ── NFT Analysis ───────────────────────────────────────────────────────────────
# Provider docs:
#   OpenSea    → https://docs.opensea.io/reference/api-overview
#   Blur       → https://docs.blur.io

VITE_OPENSEA_API_KEY=
VITE_BLUR_API_KEY=


# ── Real Exchange Connection ────────────────────────────────────────────────────
# WARNING: These secrets must be proxied server-side in production.
# Provider docs:
#   Binance    → https://binance-docs.github.io/apidocs/spot/en
#   Coinbase   → https://docs.cdp.coinbase.com/advanced-trade/docs/welcome

VITE_BINANCE_API_KEY=
VITE_BINANCE_API_SECRET=
VITE_COINBASE_API_KEY=
VITE_COINBASE_API_SECRET=
